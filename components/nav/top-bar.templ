package nav

// TopBar renders the page title + primary action button row at the top of a content area.
templ TopBar(title string) {
	<div class="flex items-center justify-between px-4 py-4 bg-base-100 border-b border-base-200">
		<h1 class="text-xl font-semibold text-base-content">{ title }</h1>
		<div class="flex items-center gap-2">
			{ children... }
		</div>
	</div>
}
