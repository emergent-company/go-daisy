package nav

// SimpleTabs renders a lightweight DaisyUI tabs-lifted strip for in-panel use.
// No HTMX — just visual tab strip; content switching is handled by the caller.
templ SimpleTabs(tabs []Tab) {
	<div role="tablist" class="tabs tabs-lifted">
		for _, tab := range tabs {
			<a
				role="tab"
				href={ templ.URL(tab.Href) }
				class={ "tab",
					templ.KV("tab-active", tab.Active) }
			>
				{ tab.Label }
			</a>
		}
	</div>
}
